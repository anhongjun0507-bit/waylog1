# Play Store 릴리스 빌드용 서명 정보.
#
# 1. 아래 명령으로 키스토어 생성 (1회만 — 반드시 백업):
#    keytool -genkey -v \
#      -keystore ~/waylog-release.jks \
#      -keyalg RSA -keysize 2048 -validity 10000 \
#      -alias waylog
#
# 2. 이 파일을 keystore.properties 로 복사하고 실제 값 채우기:
#    cp android/keystore.properties.example android/keystore.properties
#
# 3. keystore.properties 는 .gitignore 에 이미 포함됨 (절대 커밋 금지).

storeFile=/absolute/path/to/waylog-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=waylog
keyPassword=YOUR_KEY_PASSWORD
