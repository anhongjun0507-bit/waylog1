# Supabase - 공개 anon 키와 프로젝트 URL (브라우저 노출 안전)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key...

# (선택) 레거시 상대경로 이미지용 CDN 접두. 비워두면 상대경로 그대로 사용.
# VITE_MEDIA_BASE=https://media.example.com

# (선택) ShareCardModal 이 시그니처 카드에 박는 origin 도메인. Capacitor WebView 에서
# 현재 location.origin 이 capacitor:// 라 외부 공유용 카드에 어색해지므로 override 가능.
# 비워두면 빌드 환경의 location.origin 그대로 사용. 권장: 운영 웹 도메인.
# VITE_SHARE_ORIGIN=https://waylog1.vercel.app

# 주의: Anthropic API 키는 더 이상 여기에 두지 않습니다.
# 브라우저에 노출되면 안 되므로 Supabase Edge Function 비밀로 등록하세요:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# 자세한 내용: supabase/functions/claude/README.md

# Firebase Cloud Messaging (1.2.0 푸시 알림) — 모두 Vercel 측에 등록.
# Firebase Console → 프로젝트 설정 → 일반 → 웹 앱 SDK 설정에서 복사.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Cloud Messaging → 웹 푸시 인증서(VAPID) public key
VITE_FIREBASE_VAPID_KEY=

# Edge Function (Supabase secrets) 측 — 클라이언트엔 노출 안 함:
#   FIREBASE_SERVICE_ACCOUNT  (Service Account JSON 통째로)
#   VAPID_PRIVATE_KEY         (legacy Web Push 폴백용 — 1.2.0 에선 미사용)
#   CRON_SECRET               (Vercel Cron → Edge Function 인증용)
